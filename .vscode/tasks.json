{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Configure",
      "type": "shell",
      "command": "cmake -S . -B build",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "C:/Programs/msys64/ucrt64/bin;${env:PATH}"
        }
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "CMake: Build",
      "type": "shell",
      "command": "cmake --build build",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "C:/Programs/msys64/ucrt64/bin;${env:PATH}"
        }
      },
      "dependsOn": "CMake: Configure",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
