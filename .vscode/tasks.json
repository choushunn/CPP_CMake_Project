{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Configure",
      "type": "shell",
      "command": "cmake --preset vcpkg",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "C:/Programs/msys64/ucrt64/bin;${env:PATH}",
          "VCPKG_ROOT": "C:/Programs/vcpkg-2025.04.09",
          "VCPKG_FORCE_DOWNLOADED_BINARIES": "1"
        }
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "CMake: Build",
      "type": "shell",
      "command": "cmake --build --preset build",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "C:/Programs/msys64/ucrt64/bin;${env:PATH}",
          "VCPKG_ROOT": "C:/Programs/vcpkg-2025.04.09",
          "VCPKG_FORCE_DOWNLOADED_BINARIES": "1"
        }
      },
      "dependsOn": "CMake: Configure",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
